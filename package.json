{
  "name": "sticky-notes",
  "version": "2.1.5",
  "description": "Sticky Notes Chrome Extension",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "test": "jest",
    "lint": "npx eslint modules/ background.js content.js"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "babel-jest": "^30.3.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/"
    ]
  }
}
