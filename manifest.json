{
  "manifest_version": 3,
  "name": "Sticky Notes",
  "version": "2.1.8",
  "description": "Create, manage, and organize sticky notes on any webpage \u2014 with colors, dark mode, pinning, markdown, search, rich text, and more!",
  "permissions": [
    "storage",
    "downloads",
    "contextMenus",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Sticky Notes"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
